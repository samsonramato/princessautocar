---
import Layout from "../layouts/Layout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import CarCard from "../components/CarCard.astro";
import { cars } from "../data/cars.js";
import { site, reviewUrl } from "../data/site.js";

const featured = cars.filter((c) => c.featured).slice(0, 3);

// Hero background slideshow — cycles all 10 photos with a CSS crossfade.
const slides = Array.from({ length: 10 }, (_, i) => `/assets/slide${i + 1}.jpg`);
const SLIDE_SECONDS = 4;
const heroDuration = slides.length * SLIDE_SECONDS;

const stats = [
  { count: 10, suffix: "+", label: "Years Experience", icon: "calendar" },
  { count: 5000, suffix: "+", label: "Cars Repaired", icon: "wrench" },
  { count: 1000, suffix: "+", label: "Cars Sold", icon: "car" },
  { count: 100, suffix: "%", label: "Customer Satisfaction", icon: "star" },
];

const reasons = [
  { title: "Expert Auto Repair", desc: "Specialized diagnostics and maintenance for Japanese and European vehicles, plus full service for all makes and models.", icon: "wrench" },
  { title: "Quality Used Cars", desc: "Carefully selected pre-owned vehicles that undergo thorough inspection and reconditioning before sale.", icon: "car" },
  { title: "Trusted Service", desc: "Family-owned with a reputation for honesty, transparency, and fair pricing since 2007.", icon: "handshake" },
  { title: "Service Warranty", desc: "All repairs backed by our service guarantee — peace of mind with every visit.", icon: "shield" },
];

const steps = [
  { n: "01", title: "Tell Us What's Wrong", desc: "Call, message, or stop by. Describe the issue or the car you're after — no appointment needed for a quick look." },
  { n: "02", title: "Honest Diagnosis & Quote", desc: "We inspect, explain what's actually needed in plain language, and give you a clear, upfront price." },
  { n: "03", title: "Repair & Drive Away", desc: "Skilled technicians do the work right, backed by our service guarantee. You're back on the road fast." },
];

const brands = ["Toyota", "Honda", "Ford", "Chevrolet", "Nissan", "Hyundai", "Subaru", "Lexus", "BMW", "Mercedes-Benz"];

const reviews = [
  { name: "Maria G.", rating: 5, text: "Honest, fast, and fair. They explained everything and the price was exactly as quoted. Found my new mechanic for life." },
  { name: "David R.", rating: 5, text: "Bought a used car here — clean, smooth process, no pressure at all. Highly recommend Princess Auto." },
  { name: "Aisha T.", rating: 5, text: "Great family-owned shop. They fixed my AC same day and the price was very reasonable. Friendly staff!" },
];

const highlights = ["Free estimates", "Service warranty", "Se habla español"];

const icons = {
  calendar: "M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5",
  wrench: "M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75 3.75 2.25 7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75",
  car: "M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-9m9 0V5.625A2.25 2.25 0 0014.25 3.375H4.5A2.25 2.25 0 002.25 5.625v8.625m0 0V18a.75.75 0 00.75.75h2.25",
  star: "M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.562.562 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z",
  handshake: "M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5",
  shield: "M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z",
  check: "M4.5 12.75l6 6 9-13.5",
};

const starPath = "M11.48 3.5a.56.56 0 011.04 0l2.13 5.11a.56.56 0 00.47.35l5.52.44c.5.04.7.66.32.99l-4.2 3.6a.56.56 0 00-.18.56l1.28 5.38a.56.56 0 01-.84.61l-4.72-2.88a.56.56 0 00-.59 0l-4.72 2.88a.56.56 0 01-.84-.61l1.28-5.38a.56.56 0 00-.18-.56l-4.2-3.6a.56.56 0 01.32-.99l5.52-.44a.56.56 0 00.47-.35L11.48 3.5z";
---

<Layout>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-ink-950 text-white">
    <div class="absolute inset-0" aria-hidden="true">
      <div class="hero-slideshow absolute inset-0" style={`--hero-duration:${heroDuration}s`}>
        {slides.map((src, i) => (
          <div class="hero-slide" style={`background-image:url('${src}');animation-delay:${i * SLIDE_SECONDS}s`}></div>
        ))}
      </div>
      <div class="mesh absolute inset-0 opacity-70"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-ink-950 via-ink-950/90 to-ink-950/40"></div>
      <div class="bg-grid absolute inset-0 opacity-40"></div>
    </div>

    <div class="container-app relative grid items-center gap-12 py-20 lg:grid-cols-[1.1fr_0.9fr] lg:py-28">
      <div data-reveal="left">
        <span class="inline-flex items-center gap-2 rounded-full border border-gold-400/40 bg-gold-400/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-gold-300" data-i18n="hero_eyebrow">
          Family-owned in Austin since 2007
        </span>
        <h1 class="mt-5 text-4xl font-bold leading-[1.05] sm:text-5xl lg:text-6xl">
          <span data-i18n="hero_title">Trusted Auto Repair & Quality Used Cars</span>
        </h1>
        <p class="mt-5 max-w-xl text-lg text-ink-200" data-i18n="hero_subtitle">
          Honest work, fair prices, and family-like service you can rely on.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/services" class="btn-primary pulse-glow" data-i18n="btn_services">Our Services</a>
          <a href="/inventory" class="btn-outline !border-white/30 !bg-white/5 !text-white hover:!border-white" data-i18n="btn_inventory">View Cars</a>
        </div>
        <dl class="mt-10 flex flex-wrap gap-x-8 gap-y-3 text-sm text-ink-200">
          <div><dt class="inline font-semibold text-white">Address:</dt> <dd class="inline">{site.address}</dd></div>
          <div><dt class="inline font-semibold text-white">Open:</dt> <dd class="inline">Mon–Sat 9:00–6:00</dd></div>
        </dl>
      </div>

      <!-- Floating glass trust card -->
      <div class="hidden lg:block" data-reveal="right" style="--reveal-delay:150ms">
        <div class="animate-float rounded-3xl border border-white/15 bg-white/10 p-7 shadow-lift backdrop-blur-md">
          <div class="flex items-center gap-4">
            <p class="font-display text-5xl font-bold text-gold-300">5.0</p>
            <div>
              <div class="flex gap-0.5 text-gold-400">
                {Array.from({ length: 5 }).map(() => (
                  <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d={starPath} /></svg>
                ))}
              </div>
              <p class="mt-1 text-sm text-ink-200">Loved by Austin drivers</p>
            </div>
          </div>
          <div class="my-6 h-px bg-white/15"></div>
          <ul class="space-y-3">
            {highlights.map((h) => (
              <li class="flex items-center gap-3 text-sm">
                <span class="flex h-6 w-6 items-center justify-center rounded-full bg-brand-500/25 text-brand-200">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={icons.check} /></svg>
                </span>
                {h}
              </li>
            ))}
          </ul>
          <a href={site.phoneHref} class="btn-primary mt-7 w-full">Call {site.phonePrimary}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Impact / stats band (animated gradient) -->
  <section class="relative overflow-hidden py-16 text-white" style="background-image:linear-gradient(120deg,var(--color-brand-600),var(--color-iris-600))">
    <div class="bg-grid absolute inset-0 opacity-30"></div>
    <div class="blob h-64 w-64 bg-gold-400 animate-float" style="bottom:-3rem;left:-2rem;opacity:0.25"></div>
    <div class="container-app relative">
      <div class="grid grid-cols-2 gap-8 lg:grid-cols-4">
        {stats.map((s, i) => (
          <div class="text-center" data-reveal style={`--reveal-delay:${i * 90}ms`}>
            <span class="mx-auto flex h-12 w-12 items-center justify-center rounded-xl bg-white/15 backdrop-blur">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={icons[s.icon]} /></svg>
            </span>
            <p class="mt-4 font-display text-4xl font-bold sm:text-5xl">
              <span data-count={s.count} data-suffix={s.suffix}>0{s.suffix}</span>
            </p>
            <p class="mt-1 text-sm text-brand-100">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why choose -->
  <section class="section bg-dots" style="background-color:var(--color-surface)">
    <div class="container-app">
      <div data-reveal>
        <SectionHeading title="Why Choose Princess Auto Austin" titleKey="why_title"
          subtitle="We pride ourselves on exceptional service and real value for every customer." subtitleKey="why_sub" />
      </div>
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {reasons.map((r, i) => (
          <div class="card card-hover card-accent" data-reveal style={`--reveal-delay:${i * 90}ms`}>
            <span class="icon-tile">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={icons[r.icon]} /></svg>
            </span>
            <h3 class="mt-4 text-lg font-semibold text-ink-900">{r.title}</h3>
            <p class="mt-2 text-sm text-ink-500">{r.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works (dark) -->
  <section class="section relative overflow-hidden bg-ink-900 text-white">
    <div class="bg-grid absolute inset-0 opacity-30"></div>
    <div class="blob h-72 w-72 bg-brand-500 animate-float" style="top:2rem;right:-3rem"></div>
    <div class="blob h-72 w-72 bg-iris-600 animate-float" style="bottom:0;left:-3rem;animation-delay:1.5s"></div>
    <div class="container-app relative">
      <div data-reveal class="text-center">
        <span class="eyebrow !bg-white/10 !text-brand-200">Simple & transparent</span>
        <h2 class="mt-4 text-3xl font-bold sm:text-4xl">How It Works</h2>
        <p class="mx-auto mt-3 max-w-2xl text-lg text-ink-200">From the first call to driving away — no surprises, no jargon.</p>
      </div>
      <div class="mt-16 grid gap-8 md:grid-cols-3">
        {steps.map((step, i) => (
          <div class="relative rounded-2xl border border-white/10 bg-white/5 p-7 pt-10 backdrop-blur transition-all duration-300 hover:-translate-y-2 hover:border-brand-400/50" data-reveal style={`--reveal-delay:${i * 130}ms`}>
            <span class="absolute -top-6 left-6 flex h-14 w-14 items-center justify-center rounded-2xl font-display text-xl font-bold text-white shadow-glow" style="background-image:linear-gradient(135deg,var(--color-brand-500),var(--color-iris-600))">{step.n}</span>
            <h3 class="mt-3 text-lg font-semibold">{step.title}</h3>
            <p class="mt-2 text-sm text-ink-200">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured cars -->
  <section class="section bg-white">
    <div class="container-app">
      <div data-reveal>
        <SectionHeading title="Featured Cars" titleKey="featured_title"
          subtitle="Hand-picked, inspected, and ready to drive." subtitleKey="featured_sub" />
      </div>
      {featured.length > 0 ? (
        <>
          <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {featured.map((car, i) => (
              <div data-reveal style={`--reveal-delay:${i * 100}ms`}><CarCard car={car} /></div>
            ))}
          </div>
          <div class="mt-10 text-center">
            <a href="/inventory" class="btn-outline" data-i18n="btn_view_more">See All Cars</a>
          </div>
        </>
      ) : (
        <div class="mx-auto mt-10 max-w-xl rounded-3xl border border-ink-100 bg-surface px-8 py-12 text-center" style="background-color:var(--color-surface)">
          <p class="text-lg text-ink-700">Our inventory changes often — call us for current availability.</p>
          <div class="mt-6 flex flex-wrap justify-center gap-3">
            <a href={site.phoneHref} class="btn-primary">Call {site.phonePrimary}</a>
            <a href="/contact" class="btn-outline">Send a Message</a>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Brands marquee -->
  <section class="overflow-hidden border-y border-ink-100 py-12" style="background-color:var(--color-surface)">
    <div class="container-app" data-reveal>
      <p class="text-center text-sm font-semibold uppercase tracking-wide text-ink-500">All makes & models — we service them all</p>
    </div>
    <div class="relative mt-6">
      <div class="marquee gap-12">
        {[...brands, ...brands].map((b) => (
          <span class="whitespace-nowrap font-display text-2xl font-bold text-ink-200 transition-colors hover:text-brand-600">{b}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="section bg-white">
    <div class="container-app">
      <div data-reveal>
        <SectionHeading title="What Our Customers Say" titleKey="reviews_title"
          subtitle="Real reviews from drivers across Austin." subtitleKey="reviews_sub" />
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {reviews.map((rev, i) => (
          <figure class="card card-hover card-accent relative flex flex-col" data-reveal style={`--reveal-delay:${i * 100}ms`}>
            <span class="absolute right-6 top-2 font-display text-7xl leading-none text-brand-100">&rdquo;</span>
            <div class="flex gap-0.5 text-gold-400">
              {Array.from({ length: rev.rating }).map(() => (
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d={starPath} /></svg>
              ))}
            </div>
            <blockquote class="mt-4 flex-1 text-ink-700">"{rev.text}"</blockquote>
            <figcaption class="mt-5 flex items-center gap-3">
              <span class="flex h-11 w-11 items-center justify-center rounded-full text-sm font-bold text-white" style="background-image:linear-gradient(135deg,var(--color-brand-500),var(--color-iris-600))">
                {rev.name.charAt(0)}
              </span>
              <span class="font-semibold text-ink-900">{rev.name}</span>
            </figcaption>
          </figure>
        ))}
      </div>
      <div class="mt-10 text-center">
        <a href={reviewUrl} target="_blank" rel="noopener" class="btn-outline">Read more on Google</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section bg-white">
    <div class="container-app">
      <div class="relative overflow-hidden rounded-3xl bg-ink-950 px-8 py-16 text-center text-white sm:px-16" data-reveal="zoom">
        <div class="mesh absolute inset-0 opacity-80"></div>
        <div class="bg-grid absolute inset-0 opacity-30"></div>
        <div class="relative">
          <h2 class="text-3xl font-bold sm:text-4xl" data-i18n="cta_title">Need Auto Repair Today?</h2>
          <p class="mx-auto mt-3 max-w-xl text-lg text-ink-200" data-i18n="cta_sub">We'll take care of your vehicle like it's our own.</p>
          <div class="mt-8 flex flex-wrap justify-center gap-3">
            <a href="/contact" class="btn bg-white text-brand-700 hover:bg-brand-50" data-i18n="btn_book">Book an Appointment</a>
            <a href={site.phoneHref} class="btn-outline !border-white/30 !bg-white/5 !text-white hover:!border-white">Call {site.phonePrimary}</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero background crossfade slideshow (pure CSS, no JS) */
  .hero-slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    animation: heroFade var(--hero-duration, 40s) infinite;
    will-change: opacity;
  }

  @keyframes heroFade {
    0% { opacity: 0; }
    2.5% { opacity: 1; }
    10% { opacity: 1; }
    12.5% { opacity: 0; }
    100% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-slide { animation: none; }
    .hero-slide:first-child { opacity: 1; }
  }
</style>
