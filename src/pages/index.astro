---
import Layout from "../layouts/Layout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import CarCard from "../components/CarCard.astro";
import { cars } from "../data/cars.js";
import { site } from "../data/site.js";

const featured = cars.filter((c) => c.featured).slice(0, 3);

const stats = [
  { value: "10+", label: "Years Experience", icon: "calendar" },
  { value: "5,000+", label: "Cars Repaired", icon: "wrench" },
  { value: "1,000+", label: "Cars Sold", icon: "car" },
  { value: "100%", label: "Customer Satisfaction", icon: "star" },
];

const reasons = [
  { title: "Expert Auto Repair", desc: "Specialized diagnostics and maintenance for Japanese and European vehicles, plus full service for all makes and models.", icon: "wrench" },
  { title: "Quality Used Cars", desc: "Carefully selected pre-owned vehicles that undergo thorough inspection and reconditioning before sale.", icon: "car" },
  { title: "Trusted Service", desc: "Family-owned with a reputation for honesty, transparency, and fair pricing since 2007.", icon: "handshake" },
  { title: "Service Warranty", desc: "All repairs backed by our service guarantee — peace of mind with every visit.", icon: "shield" },
];

const reviews = [
  { name: "Maria G.", rating: 5, text: "Honest, fast, and fair. They explained everything and the price was exactly as quoted. Found my new mechanic for life." },
  { name: "David R.", rating: 5, text: "Bought a used Corolla here — clean car, smooth process, no pressure. Highly recommend Princess Auto." },
  { name: "Aisha T.", rating: 5, text: "Great family-owned shop. They fixed my AC same day and the price was very reasonable. Friendly staff!" },
];

const icons = {
  calendar: "M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5",
  wrench: "M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75 3.75 2.25 7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75",
  car: "M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-9m9 0V5.625A2.25 2.25 0 0014.25 3.375H4.5A2.25 2.25 0 002.25 5.625v8.625m0 0V18a.75.75 0 00.75.75h2.25",
  star: "M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.562.562 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z",
  handshake: "M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5",
  shield: "M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z",
};
---

<Layout>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-ink-900 text-white">
    <div class="absolute inset-0">
      <img src="/assets/slide1.jpg" alt="" class="h-full w-full object-cover opacity-25" />
      <div class="absolute inset-0 bg-gradient-to-r from-ink-900 via-ink-900/90 to-ink-900/40"></div>
    </div>
    <div class="container-app relative grid items-center gap-10 py-20 lg:grid-cols-2 lg:py-28">
      <div>
        <span class="eyebrow !bg-white/10 !text-brand-200" data-i18n="hero_eyebrow">Family-owned in Austin since 2007</span>
        <h1 class="mt-5 text-4xl font-bold leading-tight sm:text-5xl lg:text-6xl" data-i18n="hero_title">
          Trusted Auto Repair & Quality Used Cars in Austin
        </h1>
        <p class="mt-5 max-w-xl text-lg text-ink-200" data-i18n="hero_subtitle">
          Honest work, fair prices, and family-like service you can rely on.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/services" class="btn-primary" data-i18n="btn_services">Our Services</a>
          <a href="/inventory" class="btn-outline !border-white/30 !bg-white/5 !text-white hover:!border-white" data-i18n="btn_inventory">View Cars</a>
        </div>
        <dl class="mt-10 flex flex-wrap gap-x-8 gap-y-3 text-sm text-ink-200">
          <div><dt class="inline font-semibold text-white">Address:</dt> <dd class="inline">{site.address}</dd></div>
          <div><dt class="inline font-semibold text-white">Open:</dt> <dd class="inline">Mon–Sat 9:00–6:00</dd></div>
        </dl>
      </div>
    </div>
  </section>

  <!-- Impact / stats -->
  <section class="section">
    <div class="container-app">
      <SectionHeading eyebrow="By the numbers" eyebrowKey="" title="Our Impact" titleKey="impact_title"
        subtitle="Numbers that speak volumes about our service and expertise." subtitleKey="impact_sub" />
      <div class="mt-12 grid grid-cols-2 gap-5 lg:grid-cols-4">
        {stats.map((s) => (
          <div class="card card-hover text-center">
            <span class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-brand-50 text-brand-600">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={icons[s.icon]} /></svg>
            </span>
            <p class="mt-4 font-display text-3xl font-bold text-ink-900">{s.value}</p>
            <p class="mt-1 text-sm text-ink-500">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why choose -->
  <section class="section bg-ink-50">
    <div class="container-app">
      <SectionHeading title="Why Choose Princess Auto Austin" titleKey="why_title"
        subtitle="We pride ourselves on exceptional service and real value for every customer." subtitleKey="why_sub" />
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {reasons.map((r) => (
          <div class="card card-hover">
            <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-600 text-white">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={icons[r.icon]} /></svg>
            </span>
            <h3 class="mt-4 text-lg font-semibold text-ink-900">{r.title}</h3>
            <p class="mt-2 text-sm text-ink-500">{r.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured cars -->
  <section class="section">
    <div class="container-app">
      <SectionHeading title="Featured Cars" titleKey="featured_title"
        subtitle="Hand-picked, inspected, and ready to drive." subtitleKey="featured_sub" />
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {featured.map((car) => <CarCard car={car} />)}
      </div>
      <div class="mt-10 text-center">
        <a href="/inventory" class="btn-outline" data-i18n="btn_view_more">See All Cars</a>
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="section bg-ink-50">
    <div class="container-app">
      <SectionHeading title="What Our Customers Say" titleKey="reviews_title"
        subtitle="Real reviews from drivers across Austin." subtitleKey="reviews_sub" />
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {reviews.map((rev) => (
          <figure class="card flex flex-col">
            <div class="flex gap-0.5 text-yellow-400">
              {Array.from({ length: rev.rating }).map(() => (
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.48 3.5a.56.56 0 011.04 0l2.13 5.11a.56.56 0 00.47.35l5.52.44c.5.04.7.66.32.99l-4.2 3.6a.56.56 0 00-.18.56l1.28 5.38a.56.56 0 01-.84.61l-4.72-2.88a.56.56 0 00-.59 0l-4.72 2.88a.56.56 0 01-.84-.61l1.28-5.38a.56.56 0 00-.18-.56l-4.2-3.6a.56.56 0 01.32-.99l5.52-.44a.56.56 0 00.47-.35L11.48 3.5z" /></svg>
              ))}
            </div>
            <blockquote class="mt-4 flex-1 text-ink-700">"{rev.text}"</blockquote>
            <figcaption class="mt-4 font-semibold text-ink-900">{rev.name}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container-app">
      <div class="relative overflow-hidden rounded-3xl bg-brand-600 px-8 py-14 text-center text-white sm:px-16">
        <h2 class="text-3xl font-bold sm:text-4xl" data-i18n="cta_title">Need Auto Repair Today?</h2>
        <p class="mx-auto mt-3 max-w-xl text-lg text-brand-100" data-i18n="cta_sub">We'll take care of your vehicle like it's our own.</p>
        <a href="/contact" class="btn mt-8 bg-white text-brand-700 hover:bg-brand-50" data-i18n="btn_book">Book an Appointment</a>
      </div>
    </div>
  </section>
</Layout>
