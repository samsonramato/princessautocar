---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import { site, reviewUrl } from "../data/site.js";

const details = [
  { label: "Our Location", lines: [site.address], icon: "M15 10.5a3 3 0 11-6 0 3 3 0 016 0z M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" },
  { label: "Phone", lines: [`Primary: ${site.phonePrimary}`, `Mechanic Hiring: ${site.phoneHiring}`], icon: "M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" },
  { label: "Email", lines: [site.email], icon: "M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" },
  { label: "Operating Hours", lines: site.hours.map((h) => `${h.day}: ${h.time}`), icon: "M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" },
];
---

<Layout title="Contact & Directions in Austin" description="Contact Princess Auto to book auto repair, get a body shop estimate, or ask about a used car. Find us at 11114 N Lamar Blvd, Ste C, Austin, TX 78753.">
  <PageHero title="Contact Us" subtitle="Have a question or need to schedule a service? Send us a message or reach out directly." />

  <section class="section">
    <div class="container-app grid gap-10 lg:grid-cols-2">
      <!-- Form -->
      <div class="card card-accent" data-reveal>
        <h2 class="text-xl font-semibold text-ink-900">Get in touch</h2>
        <p class="mt-1 text-sm text-ink-500">We usually reply the same business day.</p>

        <form
          id="contactForm"
          name="contact"
          method="POST"
          enctype="multipart/form-data"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="mt-6 space-y-4"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

          <div class="grid gap-4 sm:grid-cols-2">
            <input name="name" required placeholder="Your name" class="form-input" />
            <input name="email" type="email" required placeholder="Email" class="form-input" />
          </div>
          <input name="phone" placeholder="Phone (optional)" class="form-input" />
          <textarea name="message" rows="5" required placeholder="How can we help?" class="form-input resize-none"></textarea>

          <label class="block">
            <span class="text-sm font-medium text-ink-700">Add photos (optional) — e.g. of car damage or a part</span>
            <input
              id="photoInput"
              name="photos"
              type="file"
              accept="image/png,image/jpeg,image/webp,image/gif"
              multiple
              class="mt-1 block w-full text-sm text-ink-500 file:mr-4 file:rounded-full file:border-0 file:bg-brand-50 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-brand-700 hover:file:bg-brand-100"
            />
            <span class="mt-1 block text-xs text-ink-400">JPG, PNG, WebP or GIF · up to 5 photos · 10 MB each</span>
          </label>

          <p id="photoError" class="hidden rounded-lg bg-red-50 px-3 py-2 text-sm font-medium text-red-700"></p>

          <button type="submit" class="btn-primary w-full sm:w-auto">Send Message</button>
        </form>

        <p class="mt-4 text-sm text-ink-500">
          Or call us: <a href={site.phoneHref} class="font-semibold text-brand-700">{site.phonePrimary}</a>
        </p>
      </div>

      <!-- Details -->
      <div class="space-y-4">
        {details.map((d, i) => (
          <div class="card card-hover flex gap-4" data-reveal style={`--reveal-delay:${i * 80}ms`}>
            <span class="icon-tile shrink-0">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={d.icon} /></svg>
            </span>
            <div>
              <h3 class="font-semibold text-ink-900">{d.label}</h3>
              {d.lines.map((line) => <p class="text-sm text-ink-500">{line}</p>)}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Map + review -->
    <div class="container-app mt-10 grid gap-10 lg:grid-cols-3">
      <div class="overflow-hidden rounded-3xl border border-ink-100 shadow-soft lg:col-span-2">
        <iframe
          src={site.mapEmbed}
          title="Princess Auto location"
          class="h-80 w-full"
          style="border:0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
      <div class="card flex flex-col justify-center text-center">
        <h3 class="text-lg font-semibold text-ink-900">Happy with our service?</h3>
        <p class="mt-2 text-sm text-ink-500">Leave us a review on Google — it means a lot to our family business.</p>
        <a href={reviewUrl} target="_blank" rel="noopener" class="btn-primary mt-5">Leave a Google Review</a>
      </div>
    </div>
  </section>

  <script>
    // Photo upload guard: verify each file is genuinely a raster image by
    // reading its binary signature (magic bytes) — not trusting the filename
    // or the browser-reported type, both of which an attacker can spoof.
    // SVG is intentionally rejected because it can carry embedded scripts.
    const form = document.getElementById("contactForm");
    const input = /** @type {HTMLInputElement} */ (document.getElementById("photoInput"));
    const errorBox = document.getElementById("photoError");
    const MAX_FILES = 5;
    const MAX_BYTES = 10 * 1024 * 1024; // 10 MB each

    const showError = (msg) => {
      if (!errorBox) return;
      errorBox.textContent = msg;
      errorBox.classList.remove("hidden");
    };
    const clearError = () => errorBox?.classList.add("hidden");

    // Returns true only if the first bytes match a known image signature.
    const isRealImage = async (file) => {
      const buf = new Uint8Array(await file.slice(0, 12).arrayBuffer());
      const hex = [...buf].map((b) => b.toString(16).padStart(2, "0")).join("");
      const asAscii = String.fromCharCode(...buf);
      // JPEG: FFD8FF · PNG: 89504E47 · GIF: GIF8 · WebP: RIFF....WEBP
      if (hex.startsWith("ffd8ff")) return true;
      if (hex.startsWith("89504e470d0a1a0a")) return true;
      if (asAscii.startsWith("GIF8")) return true;
      if (asAscii.startsWith("RIFF") && asAscii.slice(8, 12) === "WEBP") return true;
      return false;
    };

    let filesValid = true; // cached result; the browser already enforces required text fields

    const validateFiles = async () => {
      const files = input?.files ? Array.from(input.files) : [];
      if (files.length === 0) { clearError(); return true; }
      if (files.length > MAX_FILES) {
        showError(`Please attach no more than ${MAX_FILES} photos.`);
        return false;
      }
      for (const file of files) {
        if (file.size > MAX_BYTES) {
          showError(`"${file.name}" is larger than 10 MB. Please attach a smaller photo.`);
          return false;
        }
        if (!(await isRealImage(file))) {
          showError(`"${file.name}" is not a valid image (only JPG, PNG, WebP, or GIF are allowed).`);
          return false;
        }
      }
      clearError();
      return true;
    };

    // Validate as soon as files are chosen and cache the result.
    input?.addEventListener("change", async () => {
      filesValid = false; // pessimistic until confirmed
      filesValid = await validateFiles();
    });

    // On submit, required text fields are already validated by the browser.
    // If the photos aren't confirmed-valid, stop, re-check, then submit only if they pass.
    form?.addEventListener("submit", (e) => {
      if (filesValid) return; // photos already verified (or none attached)
      e.preventDefault();
      validateFiles().then((ok) => {
        filesValid = ok;
        if (ok) form.submit();
        else input?.focus();
      });
    });
  </script>
</Layout>
