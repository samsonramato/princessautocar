---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import { site } from "../data/site.js";

const services = [
  { title: "General Repair", desc: "Engine, transmission, electrical and more — diagnosed and fixed right the first time.", icon: "wrench" },
  { title: "Used Car Sales", desc: "Inspected, cleaned, and ready-to-drive pre-owned vehicles at fair prices.", icon: "car" },
  { title: "Body Shop", desc: "Comprehensive body repair, from minor dents to major collision damage.", icon: "sparkles" },
  { title: "Hail Damage", desc: "Complete hail damage assessment and paintless dent repair services.", icon: "cloud" },
  { title: "Brakes & Suspension", desc: "Full brake service, wheel alignment, and suspension repair.", icon: "disc" },
  { title: "Oil & Maintenance", desc: "Oil changes, filters, fluid checks, and scheduled maintenance plans.", icon: "drop" },
  { title: "Diagnostics", desc: "Computer diagnostics and check-engine light troubleshooting.", icon: "chip" },
  { title: "AC & Heating", desc: "Climate control repair, recharge, and heating system service.", icon: "snow" },
];

const icons = {
  wrench: "M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75 3.75 2.25 7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75",
  car: "M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-9m9 0V5.625A2.25 2.25 0 0014.25 3.375H4.5A2.25 2.25 0 002.25 5.625v8.625m0 0V18a.75.75 0 00.75.75h2.25",
  sparkles: "M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z",
  cloud: "M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z",
  disc: "M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 3a3 3 0 100-6 3 3 0 000 6z",
  drop: "M12 21a8.25 8.25 0 005.834-14.084.75.75 0 00-1.06 0L12 11.69 7.226 6.916a.75.75 0 00-1.06 0A8.25 8.25 0 0012 21z",
  chip: "M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z",
  snow: "M12 3v18m9-9H3m15.364-6.364L5.636 18.364m12.728 0L5.636 5.636",
};

const faqs = [
  {
    q: "Do I need an appointment for car maintenance?",
    a: `Walk-ins are welcome for quick jobs like oil changes, but calling ahead at ${site.phonePrimary} helps us get you in and out faster, especially for bigger repairs.`,
  },
  {
    q: "How much does an oil change cost?",
    a: "Pricing depends on your vehicle and oil type (conventional, synthetic blend, or full synthetic). Call us for a quick quote — we keep our maintenance prices fair and transparent.",
  },
  {
    q: "My check engine light is on — can you help?",
    a: "Yes. We run full computer diagnostics to read the trouble codes, pinpoint the real cause, and explain your options before doing any work.",
  },
  {
    q: "What kinds of repairs do you handle?",
    a: "Engine, transmission, brakes, suspension, electrical, AC and heating, diagnostics, scheduled maintenance, plus full body shop and collision work. If it's on your car, we can usually fix it.",
  },
  {
    q: "Do you offer a warranty on repairs?",
    a: "Yes — we stand behind our work with a service guarantee. Ask us about the warranty on your specific repair when you get your quote.",
  },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Auto Repair & Maintenance",
    serviceType: "Car repair, maintenance, diagnostics, and used car sales",
    description:
      "Full-service auto repair and maintenance in Austin, TX: oil changes, brakes, suspension, diagnostics, AC and heating, engine and transmission work.",
    areaServed: { "@type": "City", name: "Austin" },
    provider: { "@type": "AutoRepair", name: site.name, telephone: site.phonePrimary },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  },
];
---

<Layout
  title="Auto Repair & Car Maintenance in Austin"
  description="Full-service auto repair and maintenance in Austin, TX — oil changes, brakes, suspension, engine & transmission, diagnostics, AC, body shop, and used car sales. Honest, fair pricing."
  schema={schema}
>
  <PageHero title="Auto Repair & Maintenance Services" subtitle="Full-service auto repair, diagnostics, maintenance, and quality used cars — all under one roof." />

  <section class="section">
    <div class="container-app">
      <div class="mx-auto mb-10 max-w-2xl text-center" data-reveal>
        <span class="eyebrow">What We Do</span>
        <h2 class="mt-4 text-3xl font-bold text-ink-900 sm:text-4xl">Complete auto care under one roof</h2>
        <p class="mt-3 text-lg text-ink-500">Repairs, maintenance, body work, and quality used cars — all from one trusted Austin shop.</p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((s, i) => (
          <div class="card card-hover card-accent" data-reveal style={`--reveal-delay:${(i % 3) * 90}ms`}>
            <span class="icon-tile">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={icons[s.icon]} /></svg>
            </span>
            <h3 class="mt-4 text-lg font-semibold text-ink-900">{s.title}</h3>
            <p class="mt-2 text-sm text-ink-500">{s.desc}</p>
          </div>
        ))}
      </div>

      <!-- FAQ -->
      <div class="mx-auto mt-16 max-w-3xl">
        <div class="text-center" data-reveal>
          <span class="eyebrow">FAQ</span>
          <h2 class="mt-4 text-3xl font-bold text-ink-900 sm:text-4xl">Common questions</h2>
        </div>
        <div class="mt-8 space-y-3">
          {faqs.map((f, i) => (
            <details class="card group" data-reveal style={`--reveal-delay:${(i % 3) * 70}ms`}>
              <summary class="flex cursor-pointer items-center justify-between gap-4 text-base font-semibold text-ink-900 marker:content-['']">
                {f.q}
                <svg class="h-5 w-5 shrink-0 text-brand-600 transition-transform group-open:rotate-45" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
              </summary>
              <p class="mt-3 text-sm text-ink-500">{f.a}</p>
            </details>
          ))}
        </div>
      </div>

      <div class="relative mt-16 overflow-hidden rounded-3xl bg-gradient-to-br from-ink-900 to-brand-900 px-8 py-14 text-center text-white" data-reveal>
        <div class="blob h-56 w-56 bg-brand-500" style="bottom:-3rem;left:-2rem;opacity:0.4"></div>
        <div class="relative">
          <h2 class="text-2xl font-bold sm:text-3xl">Ready to get your car serviced?</h2>
          <p class="mt-2 text-ink-200">Book an appointment and we'll take it from there.</p>
          <div class="mt-6 flex flex-wrap justify-center gap-3">
            <a href="/contact" class="btn bg-white text-brand-700 hover:bg-brand-50" data-i18n="btn_book">Book a Service</a>
            <a href={site.phoneHref} class="btn-outline !border-white/30 !bg-white/5 !text-white hover:!border-white">Call {site.phonePrimary}</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
