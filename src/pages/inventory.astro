---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import CarCard from "../components/CarCard.astro";
import { cars } from "../data/cars.js";
import { site } from "../data/site.js";

const hasCars = cars.length > 0;

// Vehicle structured data so each car can appear in Google rich/Shopping results.
const schema = hasCars
  ? cars.map((car) => ({
      "@context": "https://schema.org",
      "@type": "Car",
      name: car.title,
      brand: car.make,
      vehicleModelDate: car.year,
      mileageFromOdometer: { "@type": "QuantitativeValue", value: parseInt(String(car.mileage).replace(/[^0-9]/g, ""), 10), unitCode: "SMI" },
      image: new URL(car.img, Astro.site).href,
      description: car.desc,
      offers: {
        "@type": "Offer",
        price: car.price,
        priceCurrency: "USD",
        availability: "https://schema.org/InStock",
        seller: { "@type": "AutoDealer", name: site.name },
      },
    }))
  : [];
---

<Layout
  title="Used Cars for Sale in Austin"
  description="Browse quality, inspected used cars for sale at Princess Auto on North Lamar Blvd. Reconditioned, clean-title vehicles at fair prices. Call for today's availability."
  schema={schema}
>
  <PageHero title="Used Cars for Sale in Austin" subtitle="Every car we sell is inspected and reconditioned before it leaves our lot." />

  <section class="section">
    <div class="container-app">
      {hasCars ? (
        <>
          <div class="mx-auto mb-10 max-w-md">
            <div class="relative">
              <svg class="pointer-events-none absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-ink-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" /></svg>
              <input
                id="searchInput"
                type="search"
                placeholder="Search make, model, year or price…"
                class="w-full rounded-full border border-ink-200 bg-white py-3 pl-11 pr-4 text-sm focus:border-brand-400 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-400"
              />
            </div>
          </div>

          <div id="inventoryList" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {cars.map((car) => <CarCard car={car} />)}
          </div>
          <p id="noResults" class="hidden py-10 text-center text-ink-500">No vehicles match your search.</p>
        </>
      ) : (
        <div class="mx-auto max-w-xl rounded-3xl border border-ink-100 bg-ink-50 px-8 py-16 text-center">
          <span class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-brand-50 text-brand-600">
            <svg class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-9m9 0V5.625A2.25 2.25 0 0014.25 3.375H4.5A2.25 2.25 0 002.25 5.625v8.625m0 0V18a.75.75 0 00.75.75h2.25" /></svg>
          </span>
          <h2 class="mt-5 text-2xl font-bold text-ink-900">Call for Current Availability</h2>
          <p class="mt-3 text-ink-500">
            Our inventory changes often. Call or message us and we'll tell you exactly what's on the lot today —
            and help you find the right vehicle for your budget.
          </p>
          <div class="mt-7 flex flex-wrap justify-center gap-3">
            <a href={site.phoneHref} class="btn-primary">Call {site.phonePrimary}</a>
            <a href="/contact" class="btn-outline">Send a Message</a>
          </div>
        </div>
      )}
    </div>
  </section>
</Layout>

{hasCars && (
  <script>
    const input = document.getElementById("searchInput");
    const list = document.getElementById("inventoryList");
    const noResults = document.getElementById("noResults");
    input?.addEventListener("input", () => {
      const q = input.value.trim().toLowerCase();
      let visible = 0;
      list?.querySelectorAll("article").forEach((card) => {
        const match = card.textContent.toLowerCase().includes(q);
        card.classList.toggle("hidden", !match);
        if (match) visible++;
      });
      noResults?.classList.toggle("hidden", visible > 0);
    });
  </script>
)}
