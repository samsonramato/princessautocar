---
const { title, subtitle } = Astro.props;
---
<section class="relative overflow-hidden bg-ink-950 text-white">
  <div class="mesh absolute inset-0 opacity-70"></div>
  <div class="bg-grid absolute inset-0 opacity-40"></div>
  <div class="blob h-56 w-56 bg-iris-600 animate-float" style="top:-2rem;right:4rem"></div>
  <div class="container-app relative py-16 text-center sm:py-24">
    <h1 class="text-4xl font-bold sm:text-5xl lg:text-6xl" data-reveal>{title}</h1>
    {subtitle && <p class="mx-auto mt-4 max-w-2xl text-lg text-ink-200" data-reveal style="--reveal-delay:120ms">{subtitle}</p>}
  </div>
</section>
