---
import { site, mapsUrl } from "../data/site.js";
const year = new Date().getFullYear();
---

<footer class="relative overflow-hidden bg-ink-950 text-ink-200">
  <div class="bg-grid absolute inset-0 opacity-20"></div>
  <div class="blob h-64 w-64 bg-brand-600" style="top:-4rem;left:20%;opacity:0.25"></div>

  <div class="container-app relative grid gap-10 py-16 sm:grid-cols-2 lg:grid-cols-4">
    <div class="sm:col-span-2 lg:col-span-1">
      <div class="flex items-center gap-3">
        <img src="/assets/logo.png" alt={`${site.name} logo`} class="h-10 w-10 rounded-lg bg-white/90 object-contain p-1" />
        <span class="font-display text-lg font-semibold text-white">{site.name}</span>
      </div>
      <p class="mt-4 max-w-xs text-sm text-ink-200/80">
        Family-owned auto repair & used-car sales serving Austin with honesty and care since 2007.
      </p>
    </div>

    <div>
      <h4 class="text-sm font-semibold text-white">Quick Links</h4>
      <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/services" class="text-ink-200/80 transition-colors hover:text-brand-300">Services</a></li>
        <li><a href="/inventory" class="text-ink-200/80 transition-colors hover:text-brand-300">Inventory</a></li>
        <li><a href="/about" class="text-ink-200/80 transition-colors hover:text-brand-300">About</a></li>
        <li><a href="/contact" class="text-ink-200/80 transition-colors hover:text-brand-300">Contact</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-sm font-semibold text-white">Contact</h4>
      <ul class="mt-4 space-y-2 text-sm">
        <li><a href={mapsUrl} target="_blank" rel="noopener" class="text-ink-200/80 transition-colors hover:text-brand-300">{site.address}</a></li>
        <li><a href={site.phoneHref} class="text-ink-200/80 transition-colors hover:text-brand-300">{site.phonePrimary}</a></li>
        <li><a href={`mailto:${site.email}`} class="text-ink-200/80 transition-colors hover:text-brand-300">{site.email}</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-sm font-semibold text-white">Hours</h4>
      <ul class="mt-4 space-y-2 text-sm text-ink-200/80">
        {site.hours.map((h) => (
          <li class="flex justify-between gap-3">
            <span>{h.day}</span><span class="text-white">{h.time}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="relative border-t border-white/10">
    <div class="container-app py-5 text-center text-xs text-ink-200/70">
      © {year} {site.name} — All rights reserved.
    </div>
  </div>
</footer>
