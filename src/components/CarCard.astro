---
import { formatPrice } from "../data/cars.js";
const { car } = Astro.props;
---
<article id={`car-${car.id}`} class="card card-hover group flex flex-col overflow-hidden p-0">
  <div class="relative aspect-[4/3] overflow-hidden">
    <img
      src={car.img}
      alt={car.title}
      loading="lazy"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
    <span class="absolute left-3 top-3 rounded-full bg-white/95 px-3 py-1 text-sm font-bold text-brand-700 shadow-soft">
      {formatPrice(car.price)}
    </span>
  </div>
  <div class="flex flex-1 flex-col p-5">
    <h3 class="text-lg font-semibold text-ink-900">{car.title}</h3>
    <p class="mt-1 text-sm text-ink-500">{car.mileage}</p>
    <p class="mt-2 flex-1 text-sm text-ink-500">{car.desc}</p>
    <a href="/contact" class="btn-outline btn-sm mt-4 self-start">Inquire</a>
  </div>
</article>
