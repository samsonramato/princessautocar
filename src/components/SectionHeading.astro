---
const { eyebrow, title, subtitle, titleKey, subtitleKey, eyebrowKey, center = true } = Astro.props;
---
<div class:list={["max-w-2xl", center && "mx-auto text-center"]}>
  {eyebrow && <span class="eyebrow" data-i18n={eyebrowKey}>{eyebrow}</span>}
  <h2 class="mt-4 text-3xl font-bold text-ink-900 sm:text-4xl" data-i18n={titleKey}>{title}</h2>
  {subtitle && <p class="mt-3 text-lg text-ink-500" data-i18n={subtitleKey}>{subtitle}</p>}
</div>
